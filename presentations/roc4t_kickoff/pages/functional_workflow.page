      align: [left, top]
      text: |
        <p><span style="color:$text;">1.</span> Client/Lead expresses a need</p>
        <p><span style="color:$text;">2.</span> Designers prepare a first base in AutoCAD or Revit</p>
        <p><span style="color:$text;">3.</span> AI agent automates repetitive tasks and prepares variants</p>
        <p><span style="color:$text;">4.</span> Project is consolidated into a clean model</p>
        <p><span style="color:$text;">5.</span> Model is pushed to Digital Twin Platform</p>
        <p><span style="color:$text;">6.</span> Lead explores the project</p>
        <p><span style="color:$text;">7.</span> Lead requests changes (e.g., "move this partition 20cm")</p>
        <p><span style="color:$text;">8.</span> AI applies modifications in Revit/AutoCAD</p>
        <p><span style="color:$text;">9.</span> Digital Twin is updated</p>
        <p><span style="color:$text;">10.</span> Project returns to validation or production</p>
