pageType: content
background:
  type: solid
  color: "$primary"
elements:
  - elementId: nav-label
    elementType: text
    bounds: [60, 24, 250, 22]
    content:
      style: "$caption"
      align: [left, middle]
      wrap: false
      text: |
        <p>03 / Target Architecture</p>
  - elementId: heading
    elementType: text
    bounds: [60, 60, 700, 42]
    content:
      style: "$heading"
      align: [left, middle]
      wrap: false
      text: |
        <p><strong>Target Architecture — 5 Layers</strong></p>
  - elementId: accent-bar
    elementType: shape
    bounds: [60, 112, 80, 4]
    shapeName: rect
    fill:
      type: solid
      color: "$accent"
  - elementId: layer5-box
    elementType: shape
    bounds: [340, 150, 600, 80]
    shapeName: roundRect
    adjustments: [8000]
    fill:
      type: solid
      color: "$accent"
  - elementId: layer5-text
    elementType: text
    bounds: [340, 150, 600, 80]
    content:
      fontSize: 18
      color: "$primary"
      fontFamily: "Arial"
      align: [center, middle]
      wrap: false
      text: |
        <p><strong>Layer 5 — AI Orchestrator Agent</strong></p>
