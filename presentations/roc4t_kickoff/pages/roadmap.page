pageType: content
background:
  type: solid
  color: "#FFFFFF"
elements:
  - elementId: nav-label
    elementType: text
    bounds: [60, 24, 200, 22]
    content:
      style: "$caption"
      align: [left, middle]
      wrap: false
      text: |
        <p>07 / 30-Day Roadmap</p>
  - elementId: heading
    elementType: text
    bounds: [60, 60, 700, 42]
    content:
      style: "$heading"
      align: [left, middle]
      wrap: false
      text: |
        <p><strong>30-Day Roadmap</strong></p>
  - elementId: accent-bar
    elementType: shape
    bounds: [60, 112, 80, 4]
    shapeName: rect
    fill:
      type: solid
      color: "$accent"
  - elementId: phase1-bar
    elementType: shape
    bounds: [60, 150, 10, 160]
    shapeName: rect
    fill:
      type: solid
      color: "$accent"
  - elementId: phase1-card
    elementType: shape
    bounds: [80, 150, 540, 160]
    shapeName: roundRect
    adjustments: [6000]
    fill:
      type: solid
      color: "$surface"
    border:
      style: solid
      width: 1
      color: "$border"
  - elementId: phase1-badge
    elementType: text
    bounds: [100, 162, 200, 22]
    content:
      fontSize: 12
      color: "$accent"
      fontFamily: "Arial"
      align: [left, middle]
      wrap: false
      text: |
        <p><strong>WEEKS 1-2</strong></p>
  - elementId: phase1-title
    elementType: text
    bounds: [100, 188, 500, 26]
    content:
      fontSize: 18
      color: "$text"
      fontFamily: "Arial"
      align: [left, middle]
      wrap: false
      text: |
        <p><strong>Phase 1 — AutoCAD POC</strong></p>
  - elementId: phase1-body
    elementType: text
    bounds: [100, 220, 500, 80]
    content:
      fontSize: 14
      color: "$textMuted"
      fontFamily: "Arial"
      lineHeight: 1.5
      align: [left, top]
      text: |
        <p>Quick productivity gain on a narrow, well-defined use case.</p>
        <p>Select one recurring task, establish simple rules, keep human validation in the loop.</p>
  - elementId: phase2-bar
    elementType: shape
    bounds: [660, 150, 10, 160]
    shapeName: rect
    fill:
      type: solid
      color: "$accent"
