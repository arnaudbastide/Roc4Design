  - elementId: insight-text
    elementType: text
    bounds: [100, 470, 1080, 60]
    content:
      fontSize: 20
      color: "$text"
      fontFamily: "Arial"
      align: [center, middle]
      text: |
        <p><em>"The AI must learn the Roc4Design method, not invent its own."</em></p>
