    content:
      fontSize: 20
      color: "$primary"
      fontFamily: "Arial"
      align: [center, middle]
      wrap: false
      text: |
        <p><strong>3</strong></p>
  - elementId: phase3-title
    elementType: text
    bounds: [930, 164, 270, 38]
    content:
      fontSize: 18
      color: "$text"
      fontFamily: "Arial"
      align: [left, middle]
      wrap: false
      text: |
        <p><strong>Supervision</strong></p>
  - elementId: phase3-body
    elementType: text
    bounds: [870, 224, 330, 180]
    content:
      fontSize: 14
      color: "$textMuted"
      fontFamily: "Arial"
